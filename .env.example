# ── Flask ─────────────────────────────────────
FLASK_ENV=development
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── MySQL ─────────────────────────────────────
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-your-mysql-password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=ims_db

# ── Mailjet (API-based mail sending) ──────────
# Get these from https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=your-mailjet-api-key
MAILJET_API_SECRET=your-mailjet-secret-key
MAILJET_SENDER_EMAIL=lalbaghenterprises@gmail.com
MAILJET_SENDER_NAME=LALBAGH ENTERPRISE

# ── Folders ───────────────────────────────────
INVOICE_DIR=invoices
UPLOAD_FOLDER=uploads

# ── UPI Payment ───────────────────────────────
# Your registered UPI ID (e.g. yourname@upi, yourname@oksbi, yourname@paytm)
COMPANY_UPI_ID=8927770267@okbizaxis
